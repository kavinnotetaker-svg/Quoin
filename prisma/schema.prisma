// ─── Models ─────────────────────────────────────────────────────────────────

model Organization {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  clerkOrgId       String           @unique @map("clerk_org_id")
  tier             OrganizationTier @default(FREE)
  stripeCustomerId String?          @map("stripe_customer_id")
  settings         Json             @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  memberships                         OrganizationMembership[]
  buildings                           Building[]
  complianceRuns                      ComplianceRun[]
  sourceArtifacts                     SourceArtifact[]
  evidenceArtifacts                   EvidenceArtifact[]
  benchmarkSubmissions                BenchmarkSubmission[]
  filingRecords                       FilingRecord[]
  filingRecordEvents                  FilingRecordEvent[]
  filingPackets                       FilingPacket[]
  benchmarkRequestItems               BenchmarkRequestItem[]
  benchmarkPackets                    BenchmarkPacket[]
  verificationItemResults             VerificationItemResult[]
  dataIssues                          DataIssue[]
  bepsRequestItems                    BepsRequestItem[]
  bepsMetricInputs                    BepsMetricInput[]
  bepsPrescriptiveItems               BepsPrescriptiveItem[]
  bepsAlternativeComplianceAgreements BepsAlternativeComplianceAgreement[]
  portfolioManagerSyncStates          PortfolioManagerSyncState[]
  operationalAnomalies                OperationalAnomaly[]
  retrofitCandidates                  RetrofitCandidate[]
  financingCases                      FinancingCase[]
  financingCaseCandidates             FinancingCaseCandidate[]
  financingPackets                    FinancingPacket[]
  penaltyRuns                         PenaltyRun[]
  submissionWorkflows                 SubmissionWorkflow[]
  submissionWorkflowEvents            SubmissionWorkflowEvent[]
  auditLogs                           AuditLog[]
  jobs                                Job[]

  @@map("organizations")
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique @map("clerk_user_id")
  email       String   @unique
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships OrganizationMembership[]

  @@map("users")
}

model OrganizationMembership {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  userId            String   @map("user_id")
  clerkMembershipId String?  @unique @map("clerk_membership_id")
  role              UserRole @default(VIEWER)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

model Building {
  id                        String                @id @default(cuid())
  organizationId            String                @map("organization_id")
  name                      String
  address                   String
  latitude                  Float
  longitude                 Float
  grossSquareFeet           Int                   @map("gross_square_feet")
  propertyType              PropertyType          @map("property_type")
  ownershipType             BuildingOwnershipType @default(PRIVATE) @map("ownership_type")
  yearBuilt                 Int?                  @map("year_built")
  isEnergyStarScoreEligible Boolean?              @map("is_energy_star_score_eligible")
  espmPropertyId            BigInt?               @map("espm_property_id")
  espmShareStatus           EspmShareStatus       @default(UNLINKED) @map("espm_share_status")
  greenButtonStatus         GreenButtonStatus     @default(NONE) @map("green_button_status")
  dataIngestionMethod       DataIngestionMethod   @default(CSV_UPLOAD) @map("data_ingestion_method")
  bepsTargetScore           Float                 @map("beps_target_score")
  maxPenaltyExposure        Float                 @default(0) @map("max_penalty_exposure")
  complianceCycle           ComplianceCycle       @default(CYCLE_1) @map("compliance_cycle")
  selectedPathway           SelectedPathway       @default(NONE) @map("selected_pathway")
  doeeBuildingId            String?               @map("doee_building_id")
  baselineYear              Int?                  @map("baseline_year")
  targetEui                 Float?                @map("target_eui")
  ward                      Int?
  hasFinancialDistress      Boolean               @default(false) @map("has_financial_distress")
  occupancyRate             Float?                @map("occupancy_rate")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  energyReadings                      EnergyReading[]
  complianceSnapshots                 ComplianceSnapshot[]
  pipelineRuns                        PipelineRun[]
  greenButtonConnection               GreenButtonConnection?
  meters                              Meter[]
  driftAlerts                         DriftAlert[]
  complianceRuns                      ComplianceRun[]
  sourceArtifacts                     SourceArtifact[]
  evidenceArtifacts                   EvidenceArtifact[]
  benchmarkSubmissions                BenchmarkSubmission[]
  filingRecords                       FilingRecord[]
  filingRecordEvents                  FilingRecordEvent[]
  filingPackets                       FilingPacket[]
  benchmarkRequestItems               BenchmarkRequestItem[]
  benchmarkPackets                    BenchmarkPacket[]
  verificationItemResults             VerificationItemResult[]
  dataIssues                          DataIssue[]
  bepsRequestItems                    BepsRequestItem[]
  bepsMetricInputs                    BepsMetricInput[]
  bepsPrescriptiveItems               BepsPrescriptiveItem[]
  bepsAlternativeComplianceAgreements BepsAlternativeComplianceAgreement[]
  portfolioManagerSyncStates          PortfolioManagerSyncState[]
  operationalAnomalies                OperationalAnomaly[]
  retrofitCandidates                  RetrofitCandidate[]
  financingCases                      FinancingCase[]
  financingCaseCandidates             FinancingCaseCandidate[]
  financingPackets                    FinancingPacket[]
  penaltyRuns                         PenaltyRun[]
  submissionWorkflows                 SubmissionWorkflow[]
  submissionWorkflowEvents            SubmissionWorkflowEvent[]
  auditLogs                           AuditLog[]
  jobs                                Job[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("buildings")
}

model Meter {
  id             String     @id @default(cuid())
  buildingId     String     @map("building_id")
  organizationId String     @map("organization_id")
  espmMeterId    BigInt?    @map("espm_meter_id")
  meterType      MeterType  @map("meter_type")
  name           String
  unit           EnergyUnit
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")

  building             Building             @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  energyReadings       EnergyReading[]
  operationalAnomalies OperationalAnomaly[]

  @@index([buildingId])
  @@index([organizationId])
  @@map("meters")
}

model EnergyReading {
  id              String       @id @default(cuid())
  buildingId      String       @map("building_id")
  organizationId  String       @map("organization_id")
  source          EnergySource
  meterType       MeterType    @map("meter_type")
  periodStart     DateTime     @map("period_start")
  periodEnd       DateTime     @map("period_end")
  consumption     Float
  unit            EnergyUnit
  consumptionKbtu Float        @map("consumption_kbtu")
  cost            Float?
  isVerified      Boolean      @default(false) @map("is_verified")
  uploadBatchId   String?      @map("upload_batch_id")
  rawPayload      Json?        @map("raw_payload")
  ingestedAt      DateTime     @default(now()) @map("ingested_at")
  meterId         String?      @map("meter_id")

  building Building @relation(fields: [buildingId, organizationId], references: [id, organizationId], onDelete: Cascade)
  meter    Meter?   @relation(fields: [meterId], references: [id])

  @@index([buildingId, periodStart(sort: Desc)])
  @@index([buildingId, source, ingestedAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("energy_readings")
}

model ComplianceSnapshot {
  id                         String           @id @default(cuid())
  buildingId                 String           @map("building_id")
  organizationId             String           @map("organization_id")
  snapshotDate               DateTime         @default(now()) @map("snapshot_date")
  triggerType                SnapshotTrigger  @map("trigger_type")
  pipelineRunId              String?          @map("pipeline_run_id")
  energyStarScore            Float?           @map("energy_star_score")
  siteEui                    Float?           @map("site_eui")
  sourceEui                  Float?           @map("source_eui")
  weatherNormalizedSiteEui   Float?           @map("weather_normalized_site_eui")
  weatherNormalizedSourceEui Float?           @map("weather_normalized_source_eui")
  complianceStatus           ComplianceStatus @map("compliance_status")
  complianceGap              Float?           @map("compliance_gap")
  estimatedPenalty           Float?           @map("estimated_penalty")
  dataQualityScore           Float?           @map("data_quality_score")
  activePathway              SelectedPathway? @map("active_pathway")
  targetScore                Float?           @map("target_score")
  targetEui                  Float?           @map("target_eui")
  penaltyInputsJson          Json?            @map("penalty_inputs_json")
  complianceRunId            String?          @unique @map("compliance_run_id")

  building                   Building          @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  pipelineRun                PipelineRun?      @relation(fields: [pipelineRunId], references: [id])
  complianceRun              ComplianceRun?    @relation(fields: [complianceRunId], references: [id])
  baselineBepsMetricInputs   BepsMetricInput[] @relation("BepsMetricBaselineSnapshot")
  evaluationBepsMetricInputs BepsMetricInput[] @relation("BepsMetricEvaluationSnapshot")

  @@index([buildingId, snapshotDate(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("compliance_snapshots")
}

model GreenButtonConnection {
  id             String            @id @default(cuid())
  buildingId     String            @unique @map("building_id")
  organizationId String            @map("organization_id")
  status         GreenButtonStatus @default(PENDING_AUTH)
  // TODO: Encrypt access and refresh tokens at rest before reaching production
  accessToken    String            @map("access_token")
  refreshToken   String            @map("refresh_token")
  resourceUri    String?           @map("resource_uri")
  subscriptionId String?           @map("subscription_id")
  tokenExpiresAt DateTime?         @map("token_expires_at")
  connectedAt    DateTime          @default(now()) @map("connected_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId, organizationId], references: [id, organizationId])

  @@unique([buildingId, organizationId])
  @@index([organizationId])
  @@map("green_button_connections")
}

model PipelineRun {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  buildingId     String?        @map("building_id")
  pipelineType   PipelineType   @map("pipeline_type")
  triggerType    TriggerType    @map("trigger_type")
  status         PipelineStatus @default(QUEUED)
  inputSummary   Json           @map("input_summary")
  outputSummary  Json?          @map("output_summary")
  llmCalls       Int            @default(0) @map("llm_calls")
  llmTokensUsed  Int?           @map("llm_tokens_used")
  llmModel       String?        @map("llm_model")
  llmCostCents   Int?           @map("llm_cost_cents")
  durationMs     Int?           @map("duration_ms")
  errorMessage   String?        @map("error_message") @db.Text
  startedAt      DateTime?      @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  building            Building?            @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  complianceSnapshots ComplianceSnapshot[]
  driftAlerts         DriftAlert[]
  complianceRuns      ComplianceRun[]

  @@unique([id, organizationId])
  @@index([pipelineType, status, createdAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("pipeline_runs")
}

model AuditLog {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id")
  organizationId String?  @map("organization_id")
  buildingId     String?  @map("building_id")
  action         String
  inputSnapshot  Json?    @map("input_snapshot")
  outputSnapshot Json?    @map("output_snapshot")
  errorCode      String?  @map("error_code")
  requestId      String?  @map("request_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  building     Building?     @relation(fields: [buildingId, organizationId], references: [id, organizationId])

  @@index([organizationId, timestamp(sort: Desc)])
  @@index([buildingId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
  @@map("audit_logs")
}

model Job {
  id             String    @id @default(cuid())
  type           String
  status         String
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  organizationId String?   @map("organization_id")
  buildingId     String?   @map("building_id")
  lastError      String?   @map("last_error") @db.Text
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  building     Building?     @relation(fields: [buildingId, organizationId], references: [id, organizationId])

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([buildingId, status, createdAt(sort: Desc)])
  @@index([type, status, createdAt(sort: Desc)])
  @@map("jobs")
}

model DriftAlert {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  buildingId     String        @map("building_id")
  pipelineRunId  String?       @map("pipeline_run_id")
  ruleId         String        @map("rule_id")
  severity       AlertSeverity
  status         AlertStatus   @default(ACTIVE)
  title          String
  description    String        @db.Text
  currentValue   Float         @map("current_value")
  threshold      Float
  aiRootCause    String?       @map("ai_root_cause") @db.Text
  detectedAt     DateTime      @default(now()) @map("detected_at")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  resolvedAt     DateTime?     @map("resolved_at")

  building    Building     @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  pipelineRun PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  @@index([buildingId, status, detectedAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("drift_alerts")
}

model RulePackage {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  jurisdiction String   @default("DC")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  versions   RuleVersion[]
  bepsCycles BepsCycleRegistry[]

  @@map("rule_packages")
}

model RuleVersion {
  id                String        @id @default(cuid())
  rulePackageId     String        @map("rule_package_id")
  sourceArtifactId  String?       @map("source_artifact_id")
  version           String
  status            VersionStatus @default(DRAFT)
  effectiveFrom     DateTime      @map("effective_from")
  effectiveTo       DateTime?     @map("effective_to")
  implementationKey String        @map("implementation_key")
  sourceMetadata    Json          @default("{}") @map("source_metadata")
  configJson        Json          @default("{}") @map("config_json")
  createdAt         DateTime      @default(now()) @map("created_at")

  rulePackage          RulePackage           @relation(fields: [rulePackageId], references: [id], onDelete: Cascade)
  sourceArtifact       SourceArtifact?       @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  complianceRuns       ComplianceRun[]
  calculationManifests CalculationManifest[]
  benchmarkSubmissions BenchmarkSubmission[]
  penaltyRuns          PenaltyRun[]

  @@unique([rulePackageId, version])
  @@index([rulePackageId, status, effectiveFrom(sort: Desc)])
  @@map("rule_versions")
}

model FactorSetVersion {
  id               String        @id @default(cuid())
  key              String
  sourceArtifactId String?       @map("source_artifact_id")
  version          String
  status           VersionStatus @default(DRAFT)
  effectiveFrom    DateTime      @map("effective_from")
  effectiveTo      DateTime?     @map("effective_to")
  sourceMetadata   Json          @default("{}") @map("source_metadata")
  factorsJson      Json          @default("{}") @map("factors_json")
  createdAt        DateTime      @default(now()) @map("created_at")

  sourceArtifact       SourceArtifact?       @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  complianceRuns       ComplianceRun[]
  calculationManifests CalculationManifest[]
  benchmarkSubmissions BenchmarkSubmission[]
  bepsCycles           BepsCycleRegistry[]
  penaltyRuns          PenaltyRun[]

  @@unique([key, version])
  @@index([key, status, effectiveFrom(sort: Desc)])
  @@map("factor_set_versions")
}

model BepsCycleRegistry {
  id                 String          @id @default(cuid())
  cycleId            String          @unique @map("cycle_id")
  complianceCycle    ComplianceCycle @unique @map("compliance_cycle")
