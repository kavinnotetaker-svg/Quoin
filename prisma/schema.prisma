  evaluationSnapshotId                 String?         @map("evaluation_snapshot_id")
  sourceArtifactId                     String?         @map("source_artifact_id")
  notesJson                            Json            @default("{}") @map("notes_json")
  createdAt                            DateTime        @default(now()) @map("created_at")
  updatedAt                            DateTime        @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id])
  building           Building            @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  baselineSnapshot   ComplianceSnapshot? @relation("BepsMetricBaselineSnapshot", fields: [baselineSnapshotId], references: [id], onDelete: SetNull)
  evaluationSnapshot ComplianceSnapshot? @relation("BepsMetricEvaluationSnapshot", fields: [evaluationSnapshotId], references: [id], onDelete: SetNull)
  sourceArtifact     SourceArtifact?     @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)

  @@unique([buildingId, complianceCycle, filingYear])
  @@index([organizationId, buildingId, filingYear])
  @@map("beps_metric_inputs")
}

model BepsPrescriptiveItem {
  id               String                     @id @default(cuid())
  organizationId   String                     @map("organization_id")
  buildingId       String                     @map("building_id")
  complianceCycle  ComplianceCycle            @map("compliance_cycle")
  filingYear       Int                        @map("filing_year")
  itemKey          String                     @map("item_key")
  name             String
  milestoneName    String?                    @map("milestone_name")
  isRequired       Boolean                    @default(true) @map("is_required")
  pointsPossible   Float                      @default(0) @map("points_possible")
  pointsEarned     Float?                     @map("points_earned")
  status           BepsPrescriptiveItemStatus @default(PLANNED)
  completedAt      DateTime?                  @map("completed_at")
  approvedAt       DateTime?                  @map("approved_at")
  dueAt            DateTime?                  @map("due_at")
  sourceArtifactId String?                    @map("source_artifact_id")
  metadata         Json                       @default("{}")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  building       Building        @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  sourceArtifact SourceArtifact? @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)

  @@unique([buildingId, complianceCycle, filingYear, itemKey])
  @@index([organizationId, buildingId, filingYear])
  @@map("beps_prescriptive_items")
}

model BepsAlternativeComplianceAgreement {
  id                  String                               @id @default(cuid())
  organizationId      String                               @map("organization_id")
  buildingId          String                               @map("building_id")
  complianceCycle     ComplianceCycle                      @map("compliance_cycle")
  filingYear          Int                                  @map("filing_year")
  agreementIdentifier String                               @map("agreement_identifier")
  pathway             BepsPathway                          @map("pathway")
  multiplier          Float                                @map("multiplier")
  status              AlternativeComplianceAgreementStatus @default(DRAFT)
  effectiveFrom       DateTime                             @map("effective_from")
  effectiveTo         DateTime?                            @map("effective_to")
  sourceArtifactId    String?                              @map("source_artifact_id")
  agreementPayload    Json                                 @default("{}") @map("agreement_payload")
  createdAt           DateTime                             @default(now()) @map("created_at")
  updatedAt           DateTime                             @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  building       Building        @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  sourceArtifact SourceArtifact? @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)

  @@unique([buildingId, complianceCycle, filingYear, agreementIdentifier])
  @@index([organizationId, buildingId, complianceCycle, filingYear, status])
  @@map("beps_alternative_compliance_agreements")
}

model PortfolioManagerSyncState {
  id                   String                     @id @default(cuid())
  organizationId       String                     @map("organization_id")
  buildingId           String                     @unique @map("building_id")
  status               PortfolioManagerSyncStatus @default(IDLE)
  lastAttemptedSyncAt  DateTime?                  @map("last_attempted_sync_at")
  lastSuccessfulSyncAt DateTime?                  @map("last_successful_sync_at")
  lastErrorMetadata    Json                       @default("{}") @map("last_error_metadata")
  sourceMetadata       Json                       @default("{}") @map("source_metadata")
  syncMetadata         Json                       @default("{}") @map("sync_metadata")
  qaPayload            Json                       @default("{}") @map("qa_payload")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  building     Building     @relation(fields: [buildingId, organizationId], references: [id, organizationId])

  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@map("portfolio_manager_sync_states")
}

model OperationalAnomaly {
  id                        String                   @id @default(cuid())
  organizationId            String                   @map("organization_id")
  buildingId                String                   @map("building_id")
  meterId                   String?                  @map("meter_id")
  anomalyType               OperationalAnomalyType   @map("anomaly_type")
  severity                  AlertSeverity
  status                    OperationalAnomalyStatus @default(ACTIVE)
  detectionHash             String                   @map("detection_hash")
  title                     String
  summary                   String                   @db.Text
  detectionWindowStart      DateTime                 @map("detection_window_start")
  detectionWindowEnd        DateTime                 @map("detection_window_end")
  comparisonWindowStart     DateTime?                @map("comparison_window_start")
  comparisonWindowEnd       DateTime?                @map("comparison_window_end")
  basisJson                 Json                     @default("{}") @map("basis_json")
  reasonCodesJson           Json                     @default("[]") @map("reason_codes_json")
  estimatedEnergyImpactKbtu Float?                   @map("estimated_energy_impact_kbtu")
  attributionJson           Json                     @default("{}") @map("attribution_json")
  metadata                  Json                     @default("{}")
  acknowledgedAt            DateTime?                @map("acknowledged_at")
  acknowledgedByType        ActorType?               @map("acknowledged_by_type")
  acknowledgedById          String?                  @map("acknowledged_by_id")
  dismissedAt               DateTime?                @map("dismissed_at")
  dismissedByType           ActorType?               @map("dismissed_by_type")
  dismissedById             String?                  @map("dismissed_by_id")
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  building     Building     @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  meter        Meter?       @relation(fields: [meterId], references: [id], onDelete: SetNull)

  @@unique([buildingId, detectionHash])
  @@index([organizationId, buildingId, status, severity, updatedAt(sort: Desc)])
  @@index([meterId])
  @@map("operational_anomalies")
}

model RetrofitCandidate {
  id                            String                  @id @default(cuid())
  organizationId                String                  @map("organization_id")
  buildingId                    String                  @map("building_id")
  sourceArtifactId              String?                 @map("source_artifact_id")
  projectType                   RetrofitProjectType     @map("project_type")
  candidateSource               RetrofitCandidateSource @default(MANUAL) @map("candidate_source")
  status                        RetrofitCandidateStatus @default(DRAFT)
  name                          String
  description                   String?                 @db.Text
  complianceCycle               ComplianceCycle?        @map("compliance_cycle")
  targetFilingYear              Int?                    @map("target_filing_year")
  estimatedCapex                Float                   @map("estimated_capex")
  estimatedIncentiveAmount      Float                   @default(0) @map("estimated_incentive_amount")
  estimatedAnnualSavingsKbtu    Float?                  @map("estimated_annual_savings_kbtu")
  estimatedAnnualSavingsUsd     Float?                  @map("estimated_annual_savings_usd")
  estimatedSiteEuiReduction     Float?                  @map("estimated_site_eui_reduction")
  estimatedSourceEuiReduction   Float?                  @map("estimated_source_eui_reduction")
  estimatedBepsImprovementPct   Float?                  @map("estimated_beps_improvement_pct")
  estimatedImplementationMonths Int?                    @map("estimated_implementation_months")
  confidenceBand                RetrofitConfidenceBand  @default(MEDIUM) @map("confidence_band")
  sourceMetadata                Json                    @default("{}") @map("source_metadata")
  createdAt                     DateTime                @default(now()) @map("created_at")
  updatedAt                     DateTime                @updatedAt @map("updated_at")

  organization            Organization             @relation(fields: [organizationId], references: [id])
  building                Building                 @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  sourceArtifact          SourceArtifact?          @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  financingCaseCandidates FinancingCaseCandidate[]

  @@index([organizationId, buildingId, status, updatedAt(sort: Desc)])
  @@index([organizationId, projectType, updatedAt(sort: Desc)])
  @@map("retrofit_candidates")
}

model FinancingCase {
  id                                String              @id @default(cuid())
  organizationId                    String              @map("organization_id")
  buildingId                        String              @map("building_id")
  name                              String
  description                       String?             @db.Text
  caseType                          FinancingCaseType   @default(SINGLE_CANDIDATE) @map("case_type")
  status                            FinancingCaseStatus @default(DRAFT)
  complianceCycle                   ComplianceCycle?    @map("compliance_cycle")
  targetFilingYear                  Int?                @map("target_filing_year")
  estimatedCapex                    Float               @default(0) @map("estimated_capex")
  estimatedAnnualSavingsKbtu        Float?              @map("estimated_annual_savings_kbtu")
  estimatedAnnualSavingsUsd         Float?              @map("estimated_annual_savings_usd")
  estimatedAvoidedPenalty           Float?              @map("estimated_avoided_penalty")
  estimatedComplianceImprovementPct Float?              @map("estimated_compliance_improvement_pct")
  casePayload                       Json                @default("{}") @map("case_payload")
  createdByType                     ActorType           @map("created_by_type")
  createdById                       String?             @map("created_by_id")
  createdAt                         DateTime            @default(now()) @map("created_at")
  updatedAt                         DateTime            @updatedAt @map("updated_at")

  organization Organization             @relation(fields: [organizationId], references: [id])
  building     Building                 @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  candidates   FinancingCaseCandidate[]
  packets      FinancingPacket[]

  @@index([organizationId, buildingId, status, updatedAt(sort: Desc)])
  @@map("financing_cases")
}

model FinancingCaseCandidate {
  id                  String   @id @default(cuid())
  organizationId      String   @map("organization_id")
  buildingId          String   @map("building_id")
  financingCaseId     String   @map("financing_case_id")
  retrofitCandidateId String   @map("retrofit_candidate_id")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")

  organization      Organization      @relation(fields: [organizationId], references: [id])
  building          Building          @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  financingCase     FinancingCase     @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)
  retrofitCandidate RetrofitCandidate @relation(fields: [retrofitCandidateId], references: [id], onDelete: Cascade)

  @@unique([financingCaseId, retrofitCandidateId])
  @@index([organizationId, buildingId, financingCaseId, sortOrder])
  @@map("financing_case_candidates")
}

model FinancingPacket {
  id               String                @id @default(cuid())
  organizationId   String                @map("organization_id")
  buildingId       String                @map("building_id")
  financingCaseId  String                @map("financing_case_id")
  complianceCycle  ComplianceCycle?      @map("compliance_cycle")
  targetFilingYear Int?                  @map("target_filing_year")
  version          Int
  status           FinancingPacketStatus @default(DRAFT)
  packetHash       String                @map("packet_hash")
  packetPayload    Json                  @default("{}") @map("packet_payload")
  generatedAt      DateTime              @default(now()) @map("generated_at")
  staleMarkedAt    DateTime?             @map("stale_marked_at")
  finalizedAt      DateTime?             @map("finalized_at")
  finalizedByType  ActorType?            @map("finalized_by_type")
  finalizedById    String?               @map("finalized_by_id")
  createdByType    ActorType             @map("created_by_type")
  createdById      String?               @map("created_by_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  building      Building      @relation(fields: [buildingId, organizationId], references: [id, organizationId])
  financingCase FinancingCase @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)

  @@unique([financingCaseId, version])
  @@index([organizationId, buildingId, generatedAt(sort: Desc)])
  @@index([financingCaseId, generatedAt(sort: Desc)])
  @@map("financing_packets")
}
