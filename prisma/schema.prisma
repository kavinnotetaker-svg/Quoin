generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum OrganizationTier {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MANAGER
  ENGINEER
  VIEWER
}

enum PropertyType {
  OFFICE
  MULTIFAMILY
  MIXED_USE
  OTHER
}

enum EspmShareStatus {
  PENDING
  LINKED
  FAILED
  UNLINKED
}

enum GreenButtonStatus {
  NONE
  PENDING_AUTH
  ACTIVE
  EXPIRED
  FAILED
}

enum DataIngestionMethod {
  GREEN_BUTTON
  CSV_UPLOAD
  MANUAL
}

enum ComplianceCycle {
  CYCLE_1
  CYCLE_2
  CYCLE_3
}

enum SelectedPathway {
  STANDARD
  PERFORMANCE
  PRESCRIPTIVE
  NONE
}

enum EnergySource {
  GREEN_BUTTON
  CSV_UPLOAD
  ESPM_SYNC
  MANUAL
}

enum MeterType {
  ELECTRIC
  GAS
  STEAM
  OTHER
}

enum EnergyUnit {
  KWH
  THERMS
  KBTU
  MMBTU
}

enum SnapshotTrigger {
  PIPELINE_RUN
  ESPM_SYNC
  MANUAL
  SCORE_CHANGE
}

enum ComplianceStatus {
  COMPLIANT
  AT_RISK
  NON_COMPLIANT
  EXEMPT
  PENDING_DATA
}

enum PipelineType {
  DATA_INGESTION
  PATHWAY_ANALYSIS
  CAPITAL_STRUCTURING
  DRIFT_DETECTION
  FULL_CYCLE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum TriggerType {
  SCHEDULED
  MANUAL
  WEBHOOK
  CSV_UPLOAD
}

enum PipelineStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model Organization {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  clerkOrgId       String           @unique @map("clerk_org_id")
  tier             OrganizationTier @default(FREE)
  stripeCustomerId String?          @map("stripe_customer_id")
  settings         Json             @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  users     User[]
  buildings Building[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  clerkUserId    String   @unique @map("clerk_user_id")
  email          String   @unique
  name           String
  role           UserRole @default(VIEWER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("users")
}

model Building {
  id                       String              @id @default(cuid())
  organizationId           String              @map("organization_id")
  name                     String
  address                  String
  latitude                 Float
  longitude                Float
  grossSquareFeet          Int                 @map("gross_square_feet")
  propertyType             PropertyType        @map("property_type")
  yearBuilt                Int?                @map("year_built")
  espmPropertyId           BigInt?             @map("espm_property_id")
  espmShareStatus          EspmShareStatus     @default(UNLINKED) @map("espm_share_status")
  greenButtonStatus         GreenButtonStatus   @default(NONE) @map("green_button_status")
  dataIngestionMethod      DataIngestionMethod @default(CSV_UPLOAD) @map("data_ingestion_method")
  bepsTargetScore          Float               @map("beps_target_score")
  maxPenaltyExposure       Float               @default(0) @map("max_penalty_exposure")
  complianceCycle          ComplianceCycle     @default(CYCLE_1) @map("compliance_cycle")
  selectedPathway          SelectedPathway     @default(NONE) @map("selected_pathway")
  doeeBuildingId           String?             @map("doee_building_id")
  baselineYear             Int?                @map("baseline_year")
  targetEui                Float?              @map("target_eui")
  ward                     Int?
  hasFinancialDistress     Boolean             @default(false) @map("has_financial_distress")
  occupancyRate            Float?              @map("occupancy_rate")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  organization          Organization              @relation(fields: [organizationId], references: [id])
  energyReadings        EnergyReading[]
  complianceSnapshots   ComplianceSnapshot[]
  pipelineRuns          PipelineRun[]
  greenButtonConnection GreenButtonConnection?
  meters                Meter[]
  driftAlerts           DriftAlert[]

  @@index([organizationId])
  @@map("buildings")
}

model Meter {
  id             String     @id @default(cuid())
  buildingId     String     @map("building_id")
  organizationId String     @map("organization_id")
  espmMeterId    BigInt?    @map("espm_meter_id")
  meterType      MeterType  @map("meter_type")
  name           String
  unit           EnergyUnit
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")

  building       Building        @relation(fields: [buildingId], references: [id])
  energyReadings EnergyReading[]

  @@index([buildingId])
  @@index([organizationId])
  @@map("meters")
}

model EnergyReading {
  id              String       @id @default(cuid())
  buildingId      String       @map("building_id")
  organizationId  String       @map("organization_id")
  source          EnergySource
  meterType       MeterType    @map("meter_type")
  periodStart     DateTime     @map("period_start")
  periodEnd       DateTime     @map("period_end")
  consumption     Float
  unit            EnergyUnit
  consumptionKbtu Float        @map("consumption_kbtu")
  sourceKbtu      Float?       @map("source_kbtu")
  sourceFactorUsed Float?      @map("source_factor_used")
  cost            Float?
  isVerified      Boolean      @default(false) @map("is_verified")
  uploadBatchId   String?      @map("upload_batch_id")
  rawPayload      Json?        @map("raw_payload")
  ingestedAt      DateTime     @default(now()) @map("ingested_at")
  meterId         String?      @map("meter_id")

  building Building @relation(fields: [buildingId], references: [id])
  meter    Meter?   @relation(fields: [meterId], references: [id])

  @@index([buildingId, periodStart(sort: Desc)])
  @@index([buildingId, source, ingestedAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("energy_readings")
}

model ComplianceSnapshot {
  id               String           @id @default(cuid())
  buildingId       String           @map("building_id")
  organizationId   String           @map("organization_id")
  snapshotDate     DateTime         @default(now()) @map("snapshot_date")
  triggerType      SnapshotTrigger  @map("trigger_type")
  pipelineRunId    String?          @map("pipeline_run_id")
  energyStarScore  Float?           @map("energy_star_score")
  siteEui          Float?           @map("site_eui")
  sourceEui        Float?           @map("source_eui")
  totalSiteKbtu    Float?           @map("total_site_kbtu")
  totalSourceKbtu  Float?           @map("total_source_kbtu")
  weatherNormalizedSiteEui Float?   @map("weather_normalized_site_eui")
  complianceStatus ComplianceStatus @map("compliance_status")
  complianceGap    Float?           @map("compliance_gap")
  estimatedPenalty Float?           @map("estimated_penalty")
  dataQualityScore Float?           @map("data_quality_score")
  activePathway    SelectedPathway?  @map("active_pathway")
  targetScore      Float?            @map("target_score")
  targetEui        Float?            @map("target_eui")
  penaltyInputsJson Json?            @map("penalty_inputs_json")

  building    Building     @relation(fields: [buildingId], references: [id])
  pipelineRun PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  @@index([buildingId, snapshotDate(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("compliance_snapshots")
}

model GreenButtonConnection {
  id             String            @id @default(cuid())
  buildingId     String            @unique @map("building_id")
  organizationId String            @map("organization_id")
  status         GreenButtonStatus @default(PENDING_AUTH)
  // TODO: Encrypt access and refresh tokens at rest before reaching production
  accessToken    String            @map("access_token")
  refreshToken   String            @map("refresh_token")
  resourceUri    String?           @map("resource_uri")
  subscriptionId String?           @map("subscription_id")
  tokenExpiresAt DateTime?         @map("token_expires_at")
  connectedAt    DateTime          @default(now()) @map("connected_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id])

  @@index([organizationId])
  @@map("green_button_connections")
}

model PipelineRun {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  buildingId     String?        @map("building_id")
  pipelineType   PipelineType   @map("pipeline_type")
  triggerType    TriggerType    @map("trigger_type")
  status         PipelineStatus @default(QUEUED)
  inputSummary   Json           @map("input_summary")
  outputSummary  Json?          @map("output_summary")
  llmCalls       Int            @default(0) @map("llm_calls")
  llmTokensUsed  Int?           @map("llm_tokens_used")
  llmModel       String?        @map("llm_model")
  llmCostCents   Int?           @map("llm_cost_cents")
  durationMs     Int?           @map("duration_ms")
  errorMessage   String?        @db.Text @map("error_message")
  startedAt      DateTime?      @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  building            Building?            @relation(fields: [buildingId], references: [id])
  complianceSnapshots ComplianceSnapshot[]
  driftAlerts         DriftAlert[]

  @@index([pipelineType, status, createdAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("pipeline_runs")
}

model DriftAlert {
  id              String        @id @default(cuid())
  organizationId  String        @map("organization_id")
  buildingId      String        @map("building_id")
  pipelineRunId   String?       @map("pipeline_run_id")
  ruleId          String        @map("rule_id")
  severity        AlertSeverity
  status          AlertStatus   @default(ACTIVE)
  title           String
  description     String        @db.Text
  currentValue    Float         @map("current_value")
  threshold       Float
  aiRootCause     String?       @db.Text @map("ai_root_cause")
  detectedAt      DateTime      @default(now()) @map("detected_at")
  acknowledgedAt  DateTime?     @map("acknowledged_at")
  resolvedAt      DateTime?     @map("resolved_at")

  building    Building     @relation(fields: [buildingId], references: [id])
  pipelineRun PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  @@index([buildingId, status, detectedAt(sort: Desc)])
  @@index([organizationId, buildingId])
  @@map("drift_alerts")
}
